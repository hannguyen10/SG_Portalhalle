--- !u!114 &1249303953
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1249303948}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01e1102f812bb834ebdebe3d92a9ea39, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueManager: {fileID: 1249303950}
  introLines:
  - "Ah\u2026 endlich jemand, der nicht einfach vorbeil\xE4uft."
  - "Willkommen in der Portalhalle des Freiburger M\xFCnsters. "
  - Wer ich bin?
  - 'Nun, wie du siehst.

'
  - "Ich hei\xDFe Gargulus."
  - Seit Jahrhunderten aus Stein und heute dein Begleiter.
  - "Damit du dich hier nicht verl\xE4ufst."
  - 'Mit WASD bewegst du dich durch die Halle. '
  - Und mit der Maus schaust du dich um.
  - Keine Sorge, Hinweise bekommst du unterwegs.
  - Also los.
  - Sieh dich um.
  - "Und wenn du mehr wissen willst\u2026 klick ruhig."
